{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    
    /* Resolution Strategy */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    
    /* JavaScript Support */
    "allowJs": true,
    "checkJs": true,
    "maxNodeModuleJsDepth": 1,

    /* Output Configuration */
    "outDir": "dist",
    "rootDir": "src/ts",
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,

    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": [
    "src/ts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}